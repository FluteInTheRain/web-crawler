# Copy this file to .env and fill in your values.
# Lines beginning with # are comments and are ignored.

# ── Target website ────────────────────────────────────────────────────────
TARGET_URL=https://example.com

# ── OpenAI ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o

# ── Crawler ───────────────────────────────────────────────────────────────
CONCURRENCY=5
# MAX_PAGES=100        # uncomment to cap the number of pages crawled

# ── Qdrant Cloud ──────────────────────────────────────────────────────────
# Sign up free at https://cloud.qdrant.io — copy the cluster URL + API key
QDRANT_URL=https://<cluster-id>.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=<your-qdrant-api-key>

# ── Storage paths (defaults shown, override if needed) ───────────────────
PAGES_DIR=out_md
KB_JSON_PATH=kb.json
COLLECTION_NAME=ai_knowledge_base

# ── Embedding model ───────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
